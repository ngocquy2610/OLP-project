<%= form_with(model: [:management, course], class: "space-y-6") do |f| %>
  <% if course.errors.any? %>
    <div class="bg-red-50 p-4 rounded-lg text-red-700 text-sm">
      <h2 class="font-bold"><%= pluralize(course.errors.count, "lỗi") %> ngăn cản việc lưu:</h2>
      <ul class="list-disc pl-5">
        <% course.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= f.label :name, "Tên khóa học", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-indigo-500 outline-none" %>
  </div>
  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :price, "Giá bán", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.number_field :price, step: 0.01, class: "w-full border rounded-lg p-2.5" %>
    </div>
    <div>
      <%= f.label :course_image, "Ảnh bìa", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= f.file_field :course_image, class: "w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
    </div>
  </div>
  <div>
    <%= f.label :description, "Mô tả khóa học", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full border rounded-lg p-2.5" %>
  </div>
  <div class="flex items-center space-x-3 pt-4">
    <%= f.submit "Lưu khóa học", class: "bg-indigo-600 text-white px-6 py-2 rounded-lg font-bold hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Hủy bỏ", profile_path(current_user), class: "text-gray-500 hover:underline" %>
  </div>
<% end %>