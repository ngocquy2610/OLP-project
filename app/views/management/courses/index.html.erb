<%= turbo_frame_tag "profile_content" do %>
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800">Quản lý Khóa học</h1>
    <%= link_to "Thêm khóa học mới", new_management_course_path, 
        class: "bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition flex items-center shadow-sm" %>
  </div>
  <div class="overflow-x-auto bg-white rounded-xl border border-gray-200">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Ảnh</th>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Tên khóa học</th>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Mô tả</th>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Giá</th>
          <th class="px-6 py-3 text-left text-xs font-bold text-gray-500 uppercase">Hành động</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-200">
        <% @courses.each do |course| %>
          <tr class="hover:bg-gray-50 transition">
            <td><%= image_tag(course.course_image, class: "w-16 h-16 object-cover rounded-lg") if course.course_image.attached? %></td>
            <td class="px-6 py-4">
              <div class="font-medium text-gray-900"><%= course.name %></div>
            </td>
            <td class="px-6 py-4 text-sm text-gray-600"><%= truncate(course.description, length: 100) %></td>
            <td class="px-6 py-4 text-sm text-gray-600">
              <%= number_to_currency(course.price, unit: "VNĐ", precision: 0, format: "%n %u") %>
            </td>
            <td class="px-6 py-4 text-right text-sm font-medium space-x-3 flex">
              <%= link_to "Sửa", edit_management_course_path(course), class: "text-indigo-600 hover:text-indigo-900",data: { turbo_frame: "profile_content" } %>
              <%= button_to "Xóa", management_course_path(course), method: :delete,
                  form: { data: { turbo_confirm: "Bạn có chắc chắn muốn xóa?" } },
                  class: "inline text-red-600 hover:text-red-900" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>