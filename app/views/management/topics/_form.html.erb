<%= form_with(model: [:management, topic], class: "space-y-6") do |f| %>
  <% if topic.errors.any? %>
    <div class="bg-red-50 p-4 rounded-lg text-red-700 text-sm mb-4">
      <h3 class="font-bold"><%= pluralize(topic.errors.count, "lỗi") %>:</h3>
      <ul class="list-disc pl-5 mt-1">
        <% topic.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= f.label :course_id, "Thuộc khóa học", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.collection_select :course_id, Course.all, :id, :name, { prompt: "Chọn một khóa học..." }, { class: "w-full border rounded-lg p-2.5 bg-white focus:ring-2 focus:ring-indigo-500 outline-none" } %>
  </div>
  <div>
    <%= f.label :name, "Tên chủ đề", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_field :name, class: "w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-indigo-500 outline-none" %>
  </div>
  <div>
    <%= f.label :description, "Mô tả chủ đề", class: "block text-sm font-semibold text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full border rounded-lg p-2.5 focus:ring-2 focus:ring-indigo-500 outline-none" %>
  </div>
  <div class="flex items-center space-x-3 pt-4">
    <%= f.submit "Lưu chủ đề", class: "bg-indigo-600 text-white px-6 py-2 rounded-lg font-bold hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Hủy bỏ", profile_path(current_user), class: "text-gray-500 hover:underline" %>
  </div>
<% end %>