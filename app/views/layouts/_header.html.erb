<nav class="sticky top-0 w-full h-20 bg-[#15a5ff]">
  <div class="flex justify-between items-center w-full h-full px-20">
    <div class="flex gap-20 items-center w-4/5">
      <a class="w-[100px] h-[100px]" href="/">
        <%= image_tag "logo-olp.svg" ,class: "w-[100px] h-[100px] rounded-full" %>
      </a>
      <form action="" class="w-2/3">
        <input type="text" placeholder="Search for anything" class="border rounded-full w-2/3 h-[40px] px-8 bg-white">
      </form>
    </div>
    <div class="flex gap-8 items-center">
      <a class="no-underline text-white hover:bg-[#ffffff] py-2 px-4 rounded-xl hover:text-[#15a5ff] text-[20px] whitespace-nowrap" href="/">Trang chủ</a>
      <%= link_to "Về chúng tôi", about_path, class: "no-underline text-white hover:bg-[#ffffff] py-2 px-4 rounded-xl hover:text-[#15a5ff] text-[20px] whitespace-nowrap" %>
      <a class="no-underline text-white hover:bg-[#ffffff] py-2 px-4 rounded-xl hover:text-[#15a5ff] text-[20px] whitespace-nowrap" href="<%= courses_path %>">Khóa học</a>
      <a class="no-underline text-white hover:bg-[#ffffff] py-2 px-4 rounded-xl hover:text-[#15a5ff] text-[20px] whitespace-nowrap" href="<%= cart_path %>">Giỏ hàng</a>
      <% if user_signed_in? %>
        <%= link_to current_user.fullname, profile_path, class: "no-underline text-white hover:bg-[#ffffff] py-2 px-4 rounded-xl hover:text-[#15a5ff] whitespace-nowrap text-[20px]" %>
        <%= link_to "Đăng xuất" , destroy_user_session_path, data: { turbo_method: :delete },
                    class: "border border-white text-white px-3 py-1 rounded-full text-sm hover:bg-red-600 hover:text-white whitespace-nowrap transition text-[20px] w-fit text-center"
                    %>
      <% else %>
        <%= link_to "Đăng nhập" , new_user_session_path,
                            class: "text-white no-underline hover:bg-[#ffffff] py-2 px-4 rounded-xl hover:text-[#15a5ff] text-[20px] w-fit whitespace-nowrap" %>
      <% end %>
