<%= turbo_frame_tag "profile_content" do %>
  <h1 class="text-2xl text-center font-bold text-gray-800 mt-5">Danh sách khóa học</h1>
  <div class="flex flex-wrap gap-4 mt-6 justify-center">
    <% @courses.each do |course| %>
      <div class="flex flex-col gap-3 justify-center items-center mt-6 border-1 p-4 rounded-lg bg-gray-50 text-gray-600 w-1/6">
        <%= image_tag(course.course_image, class: "w-full h-32 object-cover rounded-lg") if course.course_image.attached? %>
        <div class="font-bold text-gray-800 text-center"><%= course.name %></div>
        <div class="text-gray-500 text-center"><em><%= truncate(course.description, length: 200, separator: ' ', omission: "...") %></em></div>
        <div class="text-sm text-black text-center"><%= number_to_currency(course.price, unit: "VNĐ", precision: 0, format: "%n %u") %></div>
        <%= link_to "Xem chi tiết", course_path(course), class: "text-blue-500 hover:underline" %>
        <%= button_to "Add to Cart", cart_items_path(course_id: course.id), method: :post, class: "w-fit bg-blue-500 text-white text-center py-2 px-4 rounded-full border-2 mt-5 hover:bg-white hover:text-blue-500 hover:border-2 border-blue-500 transition cursor-pointer" %>
      </div>
    <% end %>
  </div>
<% end %>
