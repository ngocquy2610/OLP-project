<%= turbo_frame_tag "profile_content" do %>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between gap-4 mb-6">
      <%= link_to "Back to Courses", courses_path, class: "bg-gray-500 text-white border-1 border-gray-500 px-4 py-2 rounded hover:bg-white hover:text-gray-500 hover:border-1" %>
      <%= image_tag(@course.course_image, class: "w-32 h-32 object-cover rounded-lg") if @course.course_image.attached? %>
    </div>
    <h1 class="text-2xl text-center font-bold text-gray-800 mb-3"><%= @course.name %></h1>
    <% @topics.each do |topic|%>
      <div class="bg-white rounded-lg shadow-sm p-6 mb-6">
        <h2 class="text-xl font-bold mb-4"><%= topic.name %></h2>
        <p class="text-gray-700 mb-4"><%= topic.description %></p>
        <% topic.lessons.each do |lesson| %>
          <div class="bg-gray-100 rounded-lg shadow-sm p-4 mb-4">
            <h3 class="text-lg font-bold mb-2"><%= lesson.name %></h3>
            <p class="text-gray-600 mb-2"><%= lesson.description %></p>
          </div>
        <% end %>
      </div>
    <% end %>
    <%= button_to "Add to Cart", cart_items_path(course_id: @course.id), method: :post, class: "w-fit bg-blue-500 text-white text-center py-2 px-4 rounded-full border-2 mt-5 hover:bg-white hover:text-blue-500 hover:border-2 border-blue-500 transition cursor-pointer" %>
  </div>
<% end %>
