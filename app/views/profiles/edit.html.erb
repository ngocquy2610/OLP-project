<%= render 'layouts/header' %>
<div class="max-w-2xl mx-auto mt-10 p-8 bg-white shadow-lg rounded-xl border border-gray-100">
  <h1 class="text-2xl font-bold text-gray-800 mb-6">Chỉnh sửa hồ sơ</h1>
  <%= form_with(model: @user, url: profile_path, method: :patch, class: "space-y-6") do |f| %>
    <div>
      <%= f.label :fullname, "Họ và Tên", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :fullname, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border" %>
    </div>
    <div>
      <%= f.label :phone, "Số điện thoại", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :phone, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border" %>
    </div>
    <div>
      <%= f.label :address, "Địa chỉ", class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_area :address, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 p-2 border" %>
    </div>
    <div class="flex items-center space-x-4">
      <%= f.submit "Lưu thay đổi", class: "bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700 cursor-pointer transition" %>
      <%= link_to "Hủy", profile_path, class: "text-gray-500 hover:text-gray-700" %>
    </div>
  <% end %>
  <div class="mt-10 p-4 border-t border-red-100">
    <h3 class="text-red-600 font-bold">Khu vực nguy hiểm</h3>
    <p class="text-sm text-gray-500 mb-4">Một khi đã xóa tài khoản, bạn không thể khôi phục lại dữ liệu.</p>
    <%= button_to "Xóa tài khoản của tôi", registration_path(:user), 
      data: { confirm: "Bạn có chắc chắn muốn xóa?", turbo_confirm: "Bạn có chắc chắn muốn xóa?" },
      method: :delete, 
      class: "bg-red-50 text-red-600 px-4 py-2 rounded border border-red-200 hover:bg-red-600 hover:text-white transition" %>
  </div>
</div>