<%= render "layouts/header"%>
<div class="flex bg-gray-50">
  <div class="w-64 bg-white border-r shadow-sm flex-shrink-0">
    <div class="p-6 border-b">
      <h2 class="font-bold text-gray-800 text-lg">Hồ sơ cá nhân</h2>
    </div>
    <nav class="p-4 space-y-2">
      <%# Nút thông tin cá nhân dùng chung %>
      <%= link_to profile_path, 
          class: "block px-4 py-2 rounded-lg text-gray-700 hover:bg-indigo-50 hover:text-indigo-600 transition" do %>
        Thông tin chung
      <% end %>
      <% if current_user.student? %>
        <div class="pt-4 mt-4 border-t border-gray-100">
          <p class="px-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Student Panel</p>
          <%= link_to "#", class: "block px-4 py-2 mt-2 rounded-lg text-gray-700 hover:bg-green-50 hover:text-green-600 transition" do %>
            Thông tin khóa học
          <% end %>
        </div>
      <% end %>
      <%# Nếu là Teacher: Hiện thêm menu quản lý %>
      <% if current_user.teacher? %>
        <div class="pt-4 mt-4 border-t border-gray-100">
          <p class="px-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Teacher Panel</p>
          <%= link_to management_courses_path(id: @user.id), class: "block px-4 py-2 mt-2 rounded-lg text-gray-700 hover:bg-green-50 hover:text-green-600 transition", data: { turbo_frame: "profile_content" } do %>
            Quản lý Khóa học
          <% end %>
          <%= link_to management_topics_path(id: @user.id), class: "block px-4 py-2 mt-2 rounded-lg text-gray-700 hover:bg-green-50 hover:text-green-600 transition", data: { turbo_frame: "profile_content" } do %>
            Quản lý Chủ đề
          <% end %>
          <%= link_to management_lessons_path(id: @user.id), class: "block px-4 py-2 mt-2 rounded-lg text-gray-700 hover:bg-green-50 hover:text-green-600 transition", data: { turbo_frame: "profile_content" } do %>
            Quản lý Bài học
          <% end %>
          <%= link_to management_exams_path(id: @user.id), class: "block px-4 py-2 mt-2 rounded-lg text-gray-700 hover:bg-green-50 hover:text-green-600 transition", data: { turbo_frame: "profile_content" } do %>
            Quản lý Bài kiểm tra
          <% end %>
          <%= link_to management_practices_path(id: @user.id), class: "block px-4 py-2 mt-2 rounded-lg text-gray-700 hover:bg-green-50 hover:text-green-600 transition", data: { turbo_frame: "profile_content" } do %>
            Quản lý Bài thực hành
          <% end %>
        </div>
      <% end %>
      <%# Nếu là Admin: Hiện thêm menu quản lý hệ thống %>
      <% if current_user.admin? %>
        <div class="pt-4 mt-4 border-t border-gray-100">
          <p class="px-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Admin Panel</p>
          <%= link_to "#", class: "block px-4 py-2 mt-2 rounded-lg text-gray-700 hover:bg-red-50 hover:text-red-600 transition" do %>
            Quản trị User
          <% end %>
        </div>
      <% end %>
    </nav>
  </div>
  <div class="flex-1 p-8">
    <div class="bg-white rounded-xl shadow-sm border p-6 min-h-[400px]">
      <%# Đây là cái khung quan trọng nhất %>
      <%= turbo_frame_tag "profile_content" do %>
        <%= render "profiles/role_details/#{@user.role}" %>
      <% end %>
    </div>
  </div>
</div>
