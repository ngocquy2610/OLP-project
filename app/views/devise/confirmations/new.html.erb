<%= render "layouts/header" %>
<div class="w-1/3 mx-auto mt-10 border-1 p-10 rounded-lg shadow-lg shadow-gray-400">
  <%= link_to "Quay lại", :back, class: "bg-gray-500 text-white border-1 border-gray-500 px-4 py-2 rounded hover:bg-white hover:text-gray-500 hover:border-1" %>
  <div class="mt-5 text-[24px] text-[#74787f]">Yêu cầu gửi lại email xác nhận</div>
  <%= form_for(resource, as: resource_name, url: confirmation_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <div class="field my-5">
      <p class="mb-2"><%= f.label :email, class: "text-[24px] text-[#74787f]" %></p>
      <p><%= f.email_field :email, autofocus: false, class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2", autocomplete: "email", value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email) %></p>
    </div>
    <div class="actions">
      <%= f.submit "Resend confirmation instructions", class: "bg-green-400 border-1 border-green-400 w-fit py-2 px-5 rounded-full text-black hover:bg-white hover:text-black hover:border-1 transition cursor-pointer" %>
    </div>
  <% end %>
</div>