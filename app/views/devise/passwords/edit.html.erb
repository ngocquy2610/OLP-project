<%= render "layouts/header" %>
<div class="w-1/3 mx-auto mt-10 border-1 p-10 rounded-lg shadow-lg shadow-gray-400">
  <div class="mt-5 text-[24px] text-[#74787f]">Đặt lại mật khẩu</div>
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>
    <div class="field my-5">
      <p><%= f.label :password, "Mật khẩu mới", class: "text-[24px] text-[#74787f]" %></p>
      <% if @minimum_password_length %>
        <p class="mb-2"><em>(Tối thiểu <%= @minimum_password_length %> ký tự)</em></p>
      <% end %>
      <p><%= f.password_field :password, autofocus: false, autocomplete: "new-password", class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2" %></p>
    </div>
    <div class="field my-5">
      <p class="mb-2"><%= f.label :password_confirmation, "Xác nhận mật khẩu mới", class: "text-[24px] text-[#74787f]" %></p>
      <p><%= f.password_field :password_confirmation, autocomplete: "new-password", class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2" %></p>
    </div>
    <div class="actions">
      <%= f.submit "Đổi mật khẩu", class: "bg-green-400 border-1 border-green-400 w-fit py-2 px-5 rounded-full text-black hover:bg-white hover:text-black hover:border-1 transition cursor-pointer" %>
    </div>
  <% end %>
</div>