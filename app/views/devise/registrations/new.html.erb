<%= render "layouts/header" %>
<div class="flex justify-around mt-10">
  <div class="w-1/3">
    <p class="text-[#4F8929] text-5xl font-bold text-center">NỀN TẢNG</p>
    <p class="text-[#4F8929] text-5xl font-bold text-center mb-7">GIÁO DỤC TRỰC TUYẾN</p>
    <div><%= image_tag "login-image.png" ,class: "w-full rounded-2xl shadow-lg shadow-black" %></div>
  </div>
  <div class="w-1/2">
    <div class="text-[#1877F2] text-3xl text-center font-bold border-b-2 border-[#1877F2] p-6 w-full">Đăng ký</div>
    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>
      <div class="flex justify-between gap-10">
        <div class="w-1/2">
          <div class="field my-5">
            <p class="mb-2"><%= f.label :email, class: "text-[24px] text-[#74787f]" %></p>
            <p><%= f.email_field :email, autofocus: false, autocomplete: "email", class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2" %></p>
          </div>
          <div class="field my-5">
            <p><%= f.label :password, "Mật khẩu:", class: "text-[24px] text-[#74787f]" %></p>
            <% if @minimum_password_length %>
              <p class="mb-2"><em>(Tối thiểu <%= @minimum_password_length %> ký tự)</em></p>
            <% end %>
            <p><%= f.password_field :password, autocomplete: "new-password", class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2" %></p>
          </div>
          <div class="field my-5">
            <p class="mb-2"><%= f.label :password_confirmation, "Xác nhận mật khẩu:", class: "text-[24px] text-[#74787f]" %></p>
            <p><%= f.password_field :password_confirmation, autocomplete: "new-password", class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2" %></p>
          </div>
        </div>
        <div class="w-1/2">
          <div class="field my-5">
            <p class="mb-2"><%= f.label :fullname, "Họ và tên:", class: "text-[24px] text-[#74787f]" %></p>
            <p><%= f.text_field :fullname, class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2" %></p>
          </div>
          <div class="field my-5">
            <p class="mb-2"><%= f.label :phone, "Số điện thoại:", class: "text-[24px] text-[#74787f]" %></p>
            <p><%= f.text_field :phone, class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2" %></p>
          </div>
          <div class="field my-5">
            <p class="mb-2"><%= f.label :address, "Địa chỉ:", class: "text-[24px] text-[#74787f]" %></p>
            <p><%= f.text_area :address, rows: 1, class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2" %></p>
          </div>
          <div class="field my-5">
            <p class="mb-2"><%= f.label :role, "Tài khoản:", class: "text-[24px] text-[#74787f]" %></p>
            <%= f.select :role, 
      [['Học sinh', 'student'], ['Giáo viên', 'teacher']], 
      {}, 
      class: "text-[18px] border-1 border-[#dfe2e6] rounded-full px-5 w-full py-2" %>
          </div>
        </div>
      </div>
      <div class="actions ">
        <%= f.submit "Đăng ký", class: "w-full bg-blue-500 text-white text-center py-2 rounded-full border-2 mt-5 hover:bg-white hover:text-blue-500 hover:border-2 border-blue-500 transition cursor-pointer" %>
      </div>
      <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
        <p class="text-blue-500 hover:underline mt-5 cursor-pointer"><%= link_to "Không nhận được email xác nhận?", new_confirmation_path(resource_name) %></p>
      <% end %>
    </div>
  </div>
<% end %>